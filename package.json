{
    "name": "nextbff-ai-assistant",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "prepare": "husky",
        "prod": "pnpm build && pnpm start",
        "clean": "pnpm store prune --force && rimraf pnpm-lock.yaml node_modules .next tmp",
        "type:check": "tsc --noEmit",
        "lint:check": "eslint",
        "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,scss}\"",
        "lint:fix": "eslint . --fix",
        "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,scss}\"",
        "check-all": "pnpm type:check && pnpm lint:check && pnpm format:check",
        "fix-all": "pnpm lint:fix && pnpm format:fix"
    },
    "dependencies": {
        "@langchain/core": "^1.1.39",
        "@langchain/textsplitters": "^1.0.1",
        "@xenova/transformers": "^2.17.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "dayjs": "^1.11.20",
        "lucide-react": "^1.8.0",
        "mammoth": "^1.12.0",
        "next": "16.2.3",
        "pdfjs-dist": "^5.6.205",
        "pg": "^8.20.0",
        "radix-ui": "^1.4.3",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "shadcn": "^4.2.0",
        "sonner": "^2.0.7",
        "swr": "^2.4.1",
        "tailwind-merge": "^3.5.0",
        "tw-animate-css": "^1.4.0",
        "uuid": "^13.0.0",
        "vaul": "^1.1.2",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/pg": "^8.20.0",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "babel-plugin-react-compiler": "1.0.0",
        "eslint": "^9",
        "eslint-config-next": "16.2.3",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "prettier": "^3.8.1",
        "prettier-plugin-tailwindcss": "^0.7.2",
        "rimraf": "^6.1.3",
        "tailwindcss": "^4",
        "typescript": "^5"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx}": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.{json,css,scss}": [
            "prettier --write"
        ]
    }
}
